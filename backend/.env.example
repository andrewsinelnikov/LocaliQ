# LocaliQ Backend — Environment Variables
# Copy this file to .env and fill in the actual values

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/producers_db

# JWT Secret — use a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_strong_random_secret_key

# JWT algorithm (default: HS256)
ALGORITHM=HS256

# Token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Allowed CORS origins (comma-separated)
# Example: http://localhost:5173,https://your-domain.com
CORS_ORIGINS=http://localhost:5173
